<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_category_icon"
            android:layout_width="28dp"
            android:layout_height="28dp" android:layout_marginEnd="12dp"
            android:contentDescription="Danh mục"
            app:tint="?attr/colorPrimary"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_reminder_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Tiêu đề nhắc nhở"
                android:textSize="17sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:ellipsize="end"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_reminder_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_marginTop="2dp"
                android:text="Thời gian: 10:30 AM, 20/12/2025"
                android:textSize="13sp"
                android:textColor="@color/design_default_color_secondary_variant"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/iv_status_icon"
            android:layout_width="20dp"
            android:layout_height="20dp" android:layout_marginStart="16dp"
            android:contentDescription="Trạng thái hoàn thành"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>